---
// src/components/sections/Trust.astro
---
<section class="py-16 bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-4 divide-y md:divide-y-0 md:divide-x divide-gray-100">
      
      <!-- Trust Item 1 -->
      <div class="reveal flex flex-col items-center text-center px-4 pt-6 md:pt-0">
        <div class="flex items-center gap-1 text-gold mb-3">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="m12 17.27 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.5z"/></svg>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="m12 17.27 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.5z"/></svg>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="m12 17.27 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.5z"/></svg>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="m12 17.27 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.5z"/></svg>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="m12 17.27 4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72 3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18-1.1 4.72c-.2.86.73 1.54 1.49 1.08l4.15-2.5z"/></svg>
        </div>
        <p class="text-3xl font-heading font-bold text-primary">4.8 / 5</p>
        <p class="text-gray-500 text-sm mt-1">Más de 26 reseñas en Google</p>
      </div>

      <!-- Trust Item 2 -->
      <div class="reveal reveal-delay-1 flex flex-col items-center text-center px-4 pt-6 md:pt-0">
        <div class="w-12 h-12 rounded-full bg-primary/5 flex items-center justify-center text-primary mb-3">
          <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <p class="text-lg font-heading font-semibold text-primary">Cirujano Experto</p>
        <p class="text-gray-500 text-sm mt-1">Procedimientos seguros con aval médico.</p>
      </div>

      <!-- Trust Item 3 -->
      <div class="reveal reveal-delay-2 flex flex-col items-center text-center px-4 pt-6 md:pt-0">
        <div class="w-12 h-12 rounded-full bg-primary/5 flex items-center justify-center text-primary mb-3">
          <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"/>
          </svg>
        </div>
        <p class="text-lg font-heading font-semibold text-primary">Ambiente Seguro</p>
        <p class="text-gray-500 text-sm mt-1">Clínica amigable con LGBTQ+.</p>
      </div>

      <!-- Trust Item 4 -->
      <div class="reveal reveal-delay-3 flex flex-col items-center text-center px-4 pt-6 md:pt-0">
        <div class="w-12 h-12 rounded-full bg-primary/5 flex items-center justify-center text-primary mb-3">
          <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20"/>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <p class="text-lg font-heading font-semibold text-primary">Resultados Premium</p>
        <p class="text-gray-500 text-sm mt-1">Inversión transparente y satisfactoria.</p>
      </div>

    </div>
  </div>
</section>
